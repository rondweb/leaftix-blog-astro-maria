---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { siteConfig } from '../config/site';
---

<Layout
	title="Privacy Policy | Leaftix Blog"
	description="Privacy policy for the Leaftix Blog."
	showFooterCta={false}
	noindex={true}
>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="legal-page">
		<SiteHeader />

		<main id="main-content" class="legal-main">
			<header class="legal-header">
				<h1>Privacy Policy</h1>
				<p class="legal-intro">
					This website may collect limited personal information when you choose to contact us,
					submit a form, or interact with third-party services integrated into the site.
				</p>
				<p class="legal-updated">Last updated: June 30, 2026</p>
			</header>

			<article class="legal-content">
				<section>
					<h2>Information You Share</h2>
					<p>
						If you contact us through a form, booking link, or email, we may collect information
						such as your name, email address, company, and the contents of your message.
					</p>
					<p>
						This information is used only to respond to inquiries, discuss requested work, or
						continue a conversation you have chosen to start.
					</p>
				</section>

				<section>
					<h2>Analytics and Technical Data</h2>
					<p>
						We may use analytics, hosting logs, or performance tools to understand traffic,
						diagnose issues, and improve the website experience. This can include information
						such as browser type, device data, visited pages, and approximate geographic region.
					</p>
					<p>
						Where applicable, these tools are used in a limited and proportionate way to support
						site reliability and usability.
					</p>
					<p>
						Optional analytics or marketing tools should only be enabled after the visitor grants
						consent through the site's cookie preferences.
					</p>
				</section>

				<section>
					<h2>Cookies and Browser Storage</h2>
					<p>
						This site uses browser storage for essential preferences such as theme selection and
						cookie consent choices. Optional analytics and marketing categories can be controlled
						by the visitor through the cookie banner and preferences modal.
					</p>
					<p>
						For a fuller overview of how consent is stored and how optional categories are meant
						to be used, see the <a href="/cookies">Cookie Policy</a>.
					</p>
				</section>

				<section>
					<h2>Third-Party Services</h2>
					<p>
						This website may link to or rely on third-party services such as form providers,
						analytics platforms, scheduling tools, hosting providers, or embedded content.
						Those services may process information according to their own privacy policies.
					</p>
					<p>
						We encourage you to review the privacy practices of any third-party service you use
						through this site.
					</p>
				</section>

				<section>
					<h2>Contact</h2>
					<p>
						Questions about this policy can be directed to
						<a href="mailto:info@leaftix.com">info@leaftix.com</a>.
					</p>
				</section>
			</article>
		</main>
	</div>
</Layout>

<style>
	.legal-page {
		width: min(calc(100% - 3rem), 62rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.legal-main {
		padding: 5rem 0 0;
	}

	.legal-header {
		max-width: 46rem;
	}

	.legal-updated {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.6;
		color: var(--muted-foreground);
	}

	.legal-updated {
		margin-top: 1.25rem;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.5rem, 4.2vw, 3.9rem);
		line-height: 1.05;
		letter-spacing: -0.05em;
		font-weight: 800;
	}

	.legal-intro,
	.legal-content p {
		font-size: 1.05rem;
		line-height: 1.75;
	}

	.legal-intro {
		margin: 1.5rem 0 0;
		color: var(--muted-foreground);
	}

	.legal-content {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
	}

	.legal-content section + section {
		margin-top: 2.5rem;
	}

	h2 {
		margin: 0 0 0.85rem;
		font-size: 1.35rem;
		line-height: 1.2;
		letter-spacing: -0.03em;
	}

	.legal-content p {
		margin: 0;
		max-width: 46rem;
	}

	.legal-content p + p {
		margin-top: 1rem;
	}

	.legal-content a {
		color: inherit;
		font-weight: 700;
	}

	@media (max-width: 720px) {
		.legal-page {
			width: min(calc(100% - 1.5rem), 62rem);
			padding-top: 1rem;
		}

		.legal-main {
			padding-top: 4rem;
		}
	}
</style>