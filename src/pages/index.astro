---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { siteConfig } from '../config/site';
---

<Layout
	title={siteConfig.title}
	description={siteConfig.description}
>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="page">
		<SiteHeader />

		<main id="main-content">
			<section class="hero" id="top">
				<div class="hero-layout">
					<div class="hero-copy">
						<h1 class="display-title">The future of sustainable food production is autonomous.</h1>
						<p class="hero-text">
							Welcome to the Leaftix Blog — where we explore the intersection of artificial
							intelligence, autonomous governance, and sustainable agriculture. Discover how
							multi-agent AI, Digital Twins, and edge-native architectures are transforming
							food production from reactive monitoring to proactive governance.
						</p>
						<div class="hero-actions">
							<a class="hero-btn" href="/blog">
								<span>Read the Blog</span>
								<span aria-hidden="true">-></span>
							</a>
							<a class="hero-btn hero-btn-outline" href="/about">
								<span>About Leaftix</span>
								<span aria-hidden="true">-></span>
							</a>
						</div>
					</div>
					<div class="hero-visual">
						<img
							class="hero-logo"
							src="/leaftix-logo.png"
							alt="Leaftix Logo — Green leaf symbol representing sustainable agriculture technology"
							width="320"
							height="416"
							loading="eager"
							decoding="async"
						/>
					</div>
				</div>
			</section>

			<section class="featured-section" id="featured">
				<div class="featured-header">
					<p class="section-eyebrow">Featured Topics</p>
					<h2>Exploring the future of AI-governed agriculture</h2>
				</div>

				<div class="featured-grid">
					<article class="featured-card">
						<div class="featured-card-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M12 2a10 10 0 1 0 10 10"></path>
								<path d="M12 6v6l4 2"></path>
							</svg>
						</div>
						<h3 class="featured-card-title">Autonomous Governance</h3>
						<p class="featured-card-text">
							How multi-agent AI systems are enabling real-time, proactive decision-making in agricultural environments.
						</p>
					</article>

					<article class="featured-card">
						<div class="featured-card-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<rect x="2" y="3" width="20" height="14" rx="2"></rect>
								<line x1="8" y1="21" x2="16" y2="21"></line>
								<line x1="12" y1="17" x2="12" y2="21"></line>
							</svg>
						</div>
						<h3 class="featured-card-title">Digital Twin Technology</h3>
						<p class="featured-card-text">
							Building virtual replicas of agricultural systems to simulate, predict, and optimize production outcomes.
						</p>
					</article>

					<article class="featured-card">
						<div class="featured-card-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="10"></circle>
								<path d="M12 6v6l4 2"></path>
							</svg>
						</div>
						<h3 class="featured-card-title">Edge Architecture</h3>
						<p class="featured-card-text">
							Deploying intelligence at the edge for real-time sensor processing, low-latency decisions, and resilient operations.
						</p>
					</article>

					<article class="featured-card">
						<div class="featured-card-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M12 2L2 7l10 5 10-5-10-5z"></path>
								<path d="M2 17l10 5 10-5"></path>
								<path d="M2 12l10 5 10-5"></path>
							</svg>
						</div>
						<h3 class="featured-card-title">Sustainable Production</h3>
						<p class="featured-card-text">
							Reducing resource consumption while increasing yield through precision agriculture and AI-driven optimization.
						</p>
					</article>
				</div>
			</section>

			<section class="cta-section">
				<div class="cta-card">
					<h2 class="cta-title">Stay updated with Leaftix</h2>
					<p class="cta-text">
						Follow our journey as we build the autonomous governance infrastructure for
						sustainable food production. New articles, research insights, and product updates.
					</p>
					<div class="cta-actions">
						<a class="cta-btn" href="mailto:info@leaftix.com">
							<span>Contact us</span>
							<span aria-hidden="true">-></span>
						</a>
					</div>
				</div>
			</section>
		</main>
	</div>
</Layout>

<style>
	.page {
		position: relative;
		width: min(calc(100% - 3rem), 78rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.eyebrow,
	.section-eyebrow {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		line-height: 1.4;
		text-transform: uppercase;
		margin: 0;
		color: var(--muted-foreground);
		font-style: normal;
	}

	/* Hero */
	.hero {
		padding: 5rem 0 4rem;
	}

	.hero-layout {
		display: grid;
		grid-template-columns: minmax(0, 1.4fr) minmax(14rem, 18rem);
		gap: 2.5rem;
		align-items: center;
	}

	.hero-copy {
		max-width: 52rem;
	}

	h1 {
		margin: 0;
		font-weight: 800;
		letter-spacing: -0.05em;
		color: var(--foreground);
	}

	.hero-text {
		font-size: 1.15rem;
		line-height: 1.7;
		margin: 1.5rem 0 0;
		color: var(--muted-foreground);
		max-width: 44rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 2rem;
	}

	.hero-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		min-height: 48px;
		padding: 0.85rem 1.3rem;
		border: 1px solid var(--control-border);
		border-radius: 999px;
		font-size: 1rem;
		font-weight: 700;
		color: inherit;
		text-decoration: none;
		transition:
			transform 120ms ease,
			border-color 120ms ease,
			background-color 120ms ease;
		background: var(--foreground);
		color: var(--background);
		border-color: var(--foreground);
	}

	.hero-btn-outline {
		background: transparent;
		color: var(--foreground);
		border-color: var(--control-border);
	}

	.hero-btn:hover,
	.hero-btn:focus-visible {
		transform: translateY(-2px);
	}

	.hero-btn-outline:hover,
	.hero-btn-outline:focus-visible {
		background: var(--muted);
		border-color: var(--border-strong);
	}

	.hero-visual {
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.hero-logo {
		width: min(100%, 16rem);
		height: auto;
		display: block;
	}

	/* Featured Section */
	.featured-section {
		padding: 4rem 0;
		border-top: 1px solid var(--border);
	}

	.featured-header {
		max-width: 42rem;
		margin-bottom: 2.5rem;
	}

	.featured-header h2 {
		margin: 0.85rem 0 0;
		font-size: clamp(1.8rem, 2.6vw, 2.4rem);
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1.08;
		color: var(--foreground);
	}

	.featured-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
	}

	.featured-card {
		padding: 1.5rem;
		border: 1px solid var(--border);
		border-radius: 1.15rem;
		background: var(--card);
		transition:
			transform 140ms ease,
			box-shadow 140ms ease;
	}

	.featured-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-soft);
	}

	.featured-card-icon {
		width: 2.5rem;
		height: 2.5rem;
		display: grid;
		place-items: center;
		border-radius: 0.75rem;
		background: var(--muted);
		color: var(--foreground);
		margin-bottom: 1rem;
	}

	.featured-card-icon svg {
		width: 1.3rem;
		height: 1.3rem;
	}

	.featured-card-title {
		margin: 0 0 0.5rem;
		font-size: 1.1rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--foreground);
	}

	.featured-card-text {
		margin: 0;
		font-size: 0.98rem;
		line-height: 1.65;
		color: var(--muted-foreground);
	}

	/* CTA Section */
	.cta-section {
		padding: 3rem 0 2rem;
	}

	.cta-card {
		padding: 3rem;
		border-radius: 1.5rem;
		background: var(--muted);
		border: 1px solid var(--border);
		text-align: center;
		max-width: 48rem;
		margin: 0 auto;
	}

	.cta-title {
		margin: 0;
		font-size: clamp(1.6rem, 2.4vw, 2.2rem);
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1.08;
		color: var(--foreground);
	}

	.cta-text {
		margin: 1rem auto 0;
		max-width: 36rem;
		font-size: 1.05rem;
		line-height: 1.7;
		color: var(--muted-foreground);
	}

	.cta-actions {
		display: flex;
		justify-content: center;
		margin-top: 1.5rem;
	}

	.cta-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		min-height: 48px;
		padding: 0.85rem 1.3rem;
		border: 1px solid var(--control-border);
		border-radius: 999px;
		font-size: 1rem;
		font-weight: 700;
		color: inherit;
		text-decoration: none;
		transition:
			transform 120ms ease,
			border-color 120ms ease,
			background-color 120ms ease;
		background: var(--foreground);
		color: var(--background);
		border-color: var(--foreground);
	}

	.cta-btn:hover,
	.cta-btn:focus-visible {
		transform: translateY(-2px);
	}

	@media (max-width: 860px) {
		.hero-layout {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.hero-visual {
			order: -1;
		}

		.hero-logo {
			width: min(100%, 10rem);
		}

		.featured-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.page {
			width: min(calc(100% - 1.5rem), 78rem);
			padding-top: 1rem;
		}

		.hero {
			padding: 3rem 0 3rem;
		}

		.hero-text {
			font-size: 1.05rem;
		}

		.featured-card {
			padding: 1.25rem;
		}

		.cta-card {
			padding: 2rem 1.5rem;
		}
	}
</style>