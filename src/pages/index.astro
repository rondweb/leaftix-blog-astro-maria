---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { siteConfig } from '../config/site';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
	title={siteConfig.title}
	description={siteConfig.description}
>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="page">
		<SiteHeader />

		<main id="main-content">
			<section class="hero" id="top">
				<div class="hero-copy">
					<h1 class="display-title">The future of sustainable food production is autonomous.</h1>
					<p class="hero-text">
						Welcome to the Leaftix Blog — where we explore the intersection of artificial
						intelligence, autonomous governance, and sustainable agriculture. Discover how
						multi-agent AI, Digital Twins, and edge-native architectures are transforming
						food production from reactive monitoring to proactive governance.
					</p>
					<div class="hero-actions">
						<a class="hero-btn" href="/blog">
							<span>Read the Blog</span>
							<span aria-hidden="true">-></span>
						</a>
						<a class="hero-btn hero-btn-outline" href="/about">
							<span>About Leaftix</span>
							<span aria-hidden="true">-></span>
						</a>
					</div>
				</div>
			</section>

			<section class="projects" id="work">
				<div class="projects-header">
					<p class="section-eyebrow">Latest Posts</p>
					<h2>Recent articles from the blog</h2>
				</div>

				<div class="projects-grid">
					{sortedPosts.length === 0 && (
						<p class="empty-state">No posts yet. Check back soon!</p>
					)}

					{sortedPosts.map((post, idx) => {
						const colors = ['lime', 'cyan', 'lavender', 'mint'];
						const color = colors[idx % colors.length];
						const image = post.data.image?.url;
						const href = `/blog/${post.id.replace(/\.(md|mdx)$/, '')}`;

						return (
							<a class="project-link" href={href}>
								<article class={`project-card ${color}`}>
									<div class="project-header">
										<p class="project-name">{post.data.author}</p>
									</div>
									<h2 class="project-title">{post.data.title}</h2>
									{image && (
										<div class="project-visual desktop">
											<img
												src={image}
												alt={post.data.image?.alt || post.data.title}
												loading={idx === 0 ? 'eager' : 'lazy'}
												decoding="async"
											/>
										</div>
									)}
								</article>
							</a>
						);
					})}
				</div>
			</section>

			<section class="cta-section">
				<div class="cta-card">
					<h2 class="cta-title">Stay updated with Leaftix</h2>
					<p class="cta-text">
						Follow our journey as we build the autonomous governance infrastructure for
						sustainable food production. New articles, research insights, and product updates.
					</p>
					<div class="cta-actions">
						<a class="cta-btn" href="mailto:info@leaftix.com">
							<span>Contact us</span>
							<span aria-hidden="true">-></span>
						</a>
					</div>
				</div>
			</section>
		</main>
	</div>
</Layout>

<style>
	.page {
		position: relative;
		width: min(calc(100% - 3rem), 78rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.eyebrow,
	.section-eyebrow {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		line-height: 1.4;
		text-transform: uppercase;
		margin: 0;
		color: var(--muted-foreground);
		font-style: normal;
	}

	/* Hero */
	.hero {
		padding: 5rem 0 4rem;
	}

	.hero-copy {
		max-width: 52rem;
	}

	h1 {
		margin: 0;
		font-weight: 800;
		letter-spacing: -0.05em;
		color: var(--foreground);
	}

	.display-title {
		font-size: clamp(2.4rem, 4vw, 3.8rem);
		line-height: 1.03;
	}

	.hero-text {
		font-size: 1.15rem;
		line-height: 1.7;
		margin: 1.5rem 0 0;
		color: var(--muted-foreground);
		max-width: 44rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 2rem;
	}

	.hero-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		min-height: 48px;
		padding: 0.85rem 1.3rem;
		border: 1px solid var(--control-border);
		border-radius: 999px;
		font-size: 1rem;
		font-weight: 700;
		color: inherit;
		text-decoration: none;
		transition:
			transform 120ms ease,
			border-color 120ms ease,
			background-color 120ms ease;
		background: var(--foreground);
		color: var(--background);
		border-color: var(--foreground);
	}

	.hero-btn-outline {
		background: transparent;
		color: var(--foreground);
		border-color: var(--control-border);
	}

	.hero-btn:hover,
	.hero-btn:focus-visible {
		transform: translateY(-2px);
	}

	.hero-btn-outline:hover,
	.hero-btn-outline:focus-visible {
		background: var(--muted);
		border-color: var(--border-strong);
	}

	/* Projects / Latest Posts */
	.projects {
		padding: 4rem 0 2rem;
		border-top: 1px solid var(--border);
	}

	.projects-header {
		max-width: 42rem;
		margin-bottom: 2.5rem;
	}

	.projects-header h2 {
		margin: 0.85rem 0 0;
		font-size: clamp(1.8rem, 2.6vw, 2.4rem);
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1.08;
		color: var(--foreground);
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
	}

	.project-link {
		text-decoration: none;
		color: inherit;
	}

	.project-card {
		padding: 1.5rem;
		border-radius: 1.25rem;
		background: var(--card);
		border: 1px solid var(--border);
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		transition:
			transform 140ms ease,
			box-shadow 140ms ease;
	}

	.project-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-soft);
	}

	.project-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.project-name {
		margin: 0;
		font-family: var(--font-mono);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted-foreground);
	}

	.project-title {
		margin: 0;
		font-size: clamp(1.2rem, 1.6vw, 1.45rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.12;
		color: var(--foreground);
	}

	.project-visual {
		margin-top: 0.5rem;
	}

	.project-visual img {
		width: 100%;
		height: auto;
		border-radius: 0.9rem;
		display: block;
	}

	.empty-state {
		grid-column: 1 / -1;
		padding: 2rem 0;
		text-align: center;
		color: var(--muted-foreground);
		font-size: 1.05rem;
	}

	/* CTA */
	.cta-section {
		padding: 3rem 0 2rem;
	}

	.cta-card {
		padding: 3rem;
		border-radius: 1.5rem;
		background: var(--muted);
		border: 1px solid var(--border);
		text-align: center;
		max-width: 48rem;
		margin: 0 auto;
	}

	.cta-title {
		margin: 0;
		font-size: clamp(1.6rem, 2.4vw, 2.2rem);
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1.08;
		color: var(--foreground);
	}

	.cta-text {
		margin: 1rem auto 0;
		max-width: 36rem;
		font-size: 1.05rem;
		line-height: 1.7;
		color: var(--muted-foreground);
	}

	.cta-actions {
		display: flex;
		justify-content: center;
		margin-top: 1.5rem;
	}

	.cta-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		min-height: 48px;
		padding: 0.85rem 1.3rem;
		border: 1px solid var(--control-border);
		border-radius: 999px;
		font-size: 1rem;
		font-weight: 700;
		color: inherit;
		text-decoration: none;
		transition:
			transform 120ms ease,
			border-color 120ms ease,
			background-color 120ms ease;
		background: var(--foreground);
		color: var(--background);
		border-color: var(--foreground);
	}

	.cta-btn:hover,
	.cta-btn:focus-visible {
		transform: translateY(-2px);
	}

	@media (max-width: 860px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.page {
			width: min(calc(100% - 1.5rem), 78rem);
			padding-top: 1rem;
		}

		.hero {
			padding: 3rem 0 3rem;
		}

		.hero-text {
			font-size: 1.05rem;
		}

		.project-card {
			padding: 1.25rem;
		}

		.cta-card {
			padding: 2rem 1.5rem;
		}
	}
</style>