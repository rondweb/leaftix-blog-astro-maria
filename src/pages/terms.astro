---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout
	title="Terms of Use | Leaftix Blog"
	description="Terms of use for the Leaftix Blog."
	showFooterCta={false}
	noindex={true}
>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="legal-page">
		<SiteHeader />

		<main id="main-content" class="legal-main">
			<header class="legal-header">
				<h1>Terms</h1>
				<p class="legal-intro">
					These terms govern the general use of this website and the materials presented on it.
					By accessing the site, you agree to use it in a lawful and respectful manner.
				</p>
				<p class="legal-updated">Last updated: June 30, 2026</p>
			</header>

			<article class="legal-content">
				<section>
					<h2>General Use</h2>
					<p>
						The content on this website is provided for general information and presentation
						purposes. We make reasonable efforts to keep it accurate and current, but do not
						guarantee that all information will always be complete, error-free, or up to date.
					</p>
				</section>

				<section>
					<h2>Intellectual Property</h2>
					<p>
						Unless otherwise stated, the content, design work, layouts, written materials, and
						visual assets on this site are the property of their respective owner and may not be
						reproduced, distributed, or reused without permission.
					</p>
					<p>
						Project names, logos, and trademarks referenced on this site remain the property of
						their respective owners.
					</p>
				</section>

				<section>
					<h2>External Links</h2>
					<p>
						This website may include links to third-party sites or services for convenience.
						Those destinations operate independently and are governed by their own terms and
						policies.
					</p>
				</section>

				<section>
					<h2>Contact</h2>
					<p>
						Questions about these terms can be directed to
						<a href="mailto:info@leaftix.com">info@leaftix.com</a>.
					</p>
				</section>
			</article>
		</main>
	</div>
</Layout>

<style>
	.legal-page {
		width: min(calc(100% - 3rem), 62rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.legal-main {
		padding: 5rem 0 0;
	}

	.legal-header {
		max-width: 46rem;
	}

	.legal-updated {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.6;
		color: var(--muted-foreground);
	}

	.legal-updated {
		margin-top: 1.25rem;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.5rem, 4.2vw, 3.9rem);
		line-height: 1.05;
		letter-spacing: -0.05em;
		font-weight: 800;
	}

	.legal-intro,
	.legal-content p {
		font-size: 1.05rem;
		line-height: 1.75;
	}

	.legal-intro {
		margin: 1.5rem 0 0;
		color: var(--muted-foreground);
	}

	.legal-content {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
	}

	.legal-content section + section {
		margin-top: 2.5rem;
	}

	h2 {
		margin: 0 0 0.85rem;
		font-size: 1.35rem;
		line-height: 1.2;
		letter-spacing: -0.03em;
	}

	.legal-content p {
		margin: 0;
		max-width: 46rem;
	}

	.legal-content p + p {
		margin-top: 1rem;
	}

	.legal-content a {
		color: inherit;
		font-weight: 700;
	}

	@media (max-width: 720px) {
		.legal-page {
			width: min(calc(100% - 1.5rem), 62rem);
			padding-top: 1rem;
		}

		.legal-main {
			padding-top: 4rem;
		}
	}
</style>