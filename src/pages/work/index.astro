---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { projects, workPageSize } from '../../data/projects';

const page = 1;
const totalPages = Math.ceil(projects.length / workPageSize);
const visibleProjects = projects.slice(0, workPageSize);
---

<Layout
	title="Works | Maria"
	description="Selected UX and product design work from Maria."
>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="works-page">
		<SiteHeader />

		<main id="main-content" class="works-main">
			<header class="works-hero">
				<p class="works-eyebrow">Selected work</p>
				<h1>Projects built to make complex things feel clear, useful, and easier to trust.</h1>
			</header>

			<section class="works-list" aria-label="Project list">
				{
					visibleProjects.map((project) => (
						<article class="work-card">
							<div class="work-copy">
								<p class="work-name">{project.name}</p>
								<h2>{project.title}</h2>
								<p class="work-description">{project.description}</p>

								<div class="actions">
									<a href={project.href}>
										<span>View case study</span>
										<span aria-hidden="true">-&gt;</span>
									</a>
								</div>
							</div>

							<a class="work-visual" href={project.href}>
								<Image
									class={project.imageClass}
									src={project.image}
									alt={project.alt}
									loading="lazy"
									decoding="async"
									widths={[640, 960, 1280]}
									sizes="(max-width: 860px) 100vw, 55vw"
								/>
							</a>
						</article>
					))
				}
			</section>

			<nav class="pagination" aria-label="Works pagination">
				{
					totalPages > 1 &&
						Array.from({ length: totalPages }, (_, index) => {
							const pageNumber = index + 1;
							const href = pageNumber === 1 ? '/work' : `/work/page/${pageNumber}`;

							return (
								<a
									class:list={['pagination-link', page === pageNumber && 'is-current']}
									href={href}
									aria-current={page === pageNumber ? 'page' : undefined}
								>
									{pageNumber}
								</a>
							);
						})
				}
			</nav>
		</main>
	</div>
</Layout>

<style>
	.works-page {
		width: min(calc(100% - 3rem), 78rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.works-main {
		padding-top: 4.5rem;
	}

	.works-hero {
		max-width: 100%;
	}

	.works-eyebrow,
	.work-name {
		margin: 0;
		font-size: 0.95rem;
		font-style: italic;
		font-weight: 500;
		letter-spacing: -0.02em;
		color: var(--muted-foreground);
	}

	h1,
	h2 {
		margin: 0;
		font-weight: 800;
		letter-spacing: -0.05em;
		color: var(--foreground);
	}

	h1 {
		margin-top: 1rem;
		font-size: clamp(2.6rem, 4.6vw, 4.4rem);
		line-height: 1.03;
	}

	h2 {
		font-size: clamp(1.6rem, 2.1vw, 2.2rem);
		line-height: 1.08;
	}

	.works-intro,
	.work-description {
		font-size: 1.05rem;
		line-height: 1.75;
		color: var(--muted-foreground);
	}

	.works-intro {
		max-width: 42rem;
		margin: 1.35rem 0 0;
	}

	.works-list {
		display: grid;
		gap: 1.5rem;
		margin-top: 3rem;
	}

	.work-card {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(22rem, 1.1fr);
		gap: 2rem;
		align-items: start;
		padding: 1.5rem;
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: 1.5rem;
	}

	.work-copy {
		display: grid;
		align-content: start;
		gap: 1rem;
	}

	.work-description {
		max-width: 34rem;
		margin: 0;
	}

	.actions {
		display: flex;
		margin-top: 0.5rem;
	}

	.actions a,
	.pagination-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		min-height: 48px;
		padding: 0.85rem 1.1rem;
		border: 1px solid var(--control-border);
		border-radius: 999px;
		font-size: 1rem;
		font-weight: 700;
		color: inherit;
		text-decoration: none;
		transition:
			transform 120ms ease,
			border-color 120ms ease,
			background-color 120ms ease;
	}

	.pagination-link {
		width: 3.25rem;
		height: 3.25rem;
		min-height: 3.25rem;
		padding: 0;
		flex: 0 0 3.25rem;
	}

	.actions a:hover,
	.actions a:focus-visible,
	.pagination-link:hover,
	.pagination-link:focus-visible {
		transform: translateY(-1px);
		background: var(--muted);
		border-color: var(--border-strong);
	}

	.pagination-link.is-current {
		background: var(--foreground);
		border-color: var(--foreground);
		color: var(--background);
	}

	.pagination-link.is-current:hover,
	.pagination-link.is-current:focus-visible {
		transform: none;
		background: var(--foreground);
		border-color: var(--foreground);
	}

	.work-visual {
		display: block;
		padding: 0;
		border-radius: 1rem;
		text-decoration: none;
		align-self: start;
	}

	.project-preview-image {
		width: 100%;
		height: auto;
		display: block;
		max-height: none;
		object-fit: initial;
		object-position: initial;
		border-radius: 1rem;
		box-shadow: var(--shadow-medium);
	}

	.pagination {
		display: flex;
		gap: 0.75rem;
		justify-content: center;
		margin-top: 2rem;
	}

	@media (max-width: 860px) {
		.work-card {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}
	}

	@media (max-width: 720px) {
		.works-page {
			width: min(calc(100% - 1.5rem), 78rem);
			padding-top: 1rem;
		}

		.works-main {
			padding-top: 4rem;
		}

		.work-card {
			padding: 1.2rem;
			gap: 1.25rem;
		}

	}
</style>
