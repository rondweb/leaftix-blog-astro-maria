---
import { siteConfig } from '../config/site';

const { showCta = true } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="shared-footer">
	<div class:list={['shared-footer-inner', !showCta && 'shared-footer-inner-no-cta']}>
		{
			showCta && (
				<div class="shared-footer-cta">
					<h2>Let's build the future of autonomous food production together.</h2>
					<p>
						Follow our journey or reach out to learn more about Leaftix GaiaOS and how AI is transforming sustainable agriculture.
					</p>
					<a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
				</div>
			)
		}

		<div class="shared-footer-meta">
			<div class="shared-footer-links">
				{
					siteConfig.socialLinks.map((link) => (
						<a href={link.href} target="_blank" rel="noopener noreferrer">
							{link.label}
						</a>
					))
				}
			</div>
			<div class="shared-footer-note">
				<div class="shared-footer-legal">
					{siteConfig.legalLinks.map((link) => <a href={link.href}>{link.label}</a>)}
					<button
						class="footer-cookie-btn"
						type="button"
						onclick="window.dispatchEvent(new CustomEvent('leaftix:openCookieConsent'))"
					>
						Cookie Preferences
					</button>
				</div>
				<p>&copy; {currentYear} {siteConfig.name}. AI for Sustainable Food Production.</p>
			</div>
		</div>
	</div>
</footer>