---
import { siteConfig } from '../config/site';
const currentPath = Astro.url.pathname || '/';
const menuPanelId = 'shared-menu-panel';
const mobileMenuPanelId = 'shared-mobile-menu-panel';
const mobileSubmenuPanelId = 'shared-mobile-submenu-panel';
---

<header class="shared-header">
	<a class="shared-brand" href="/" aria-label={`${siteConfig.name} homepage`}>
		<span class="shared-brand-mark">{siteConfig.name}</span>
	</a>

	<div class="shared-header-actions">
		<nav class="shared-nav shared-nav-desktop" aria-label="Primary navigation">
			{siteConfig.navLinks.map((link) => (
				<a href={link.href} aria-current={link.href === currentPath ? 'page' : undefined}>
					{link.label}
				</a>
			))}

			<div class="shared-menu">
				<button
					class="shared-menu-trigger"
					type="button"
					aria-haspopup="menu"
					aria-expanded="false"
					aria-controls={menuPanelId}
				>
					<span>Other</span>
					<img src="/icons/chevron-down.svg" alt="" width="16" height="16" />
				</button>
				<div class="shared-menu-panel" id={menuPanelId} role="menu" aria-label="More navigation pages">
					{siteConfig.extraPages.map((link) => (
						<a href={link.href} role="menuitem">
							{link.label}
						</a>
					))}
				</div>
			</div>
		</nav>

		<button
			class="shared-theme-toggle"
			type="button"
			data-theme-toggle
			aria-label="Switch to dark mode"
			aria-pressed="false"
		>
			<span class="shared-theme-toggle-icons" aria-hidden="true">
				<svg
					class="shared-theme-icon shared-theme-icon-sun"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.8"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<circle cx="12" cy="12" r="4.25"></circle>
					<path d="M12 2.75v2.5"></path>
					<path d="M12 18.75v2.5"></path>
					<path d="M21.25 12h-2.5"></path>
					<path d="M5.25 12h-2.5"></path>
					<path d="M18.54 5.46l-1.77 1.77"></path>
					<path d="M7.23 16.77l-1.77 1.77"></path>
					<path d="M18.54 18.54l-1.77-1.77"></path>
					<path d="M7.23 7.23L5.46 5.46"></path>
				</svg>
				<svg
					class="shared-theme-icon shared-theme-icon-moon"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.8"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M20.2 14.35A8.75 8.75 0 1 1 9.65 3.8 7 7 0 0 0 20.2 14.35Z"></path>
				</svg>
			</span>
		</button>

		<details class="shared-nav-mobile">
			<summary
				class="shared-nav-toggle"
				aria-label="Toggle navigation menu"
				aria-expanded="false"
				aria-controls={mobileMenuPanelId}
			>
				<span class="shared-nav-toggle-box" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
				</span>
			</summary>

			<nav class="shared-mobile-panel" id={mobileMenuPanelId} aria-label="Mobile navigation">
				<a class="shared-mobile-brand" href="/" aria-label={`${siteConfig.name} homepage`}>
					{siteConfig.name}
				</a>

				{siteConfig.navLinks.map((link) => <a href={link.href}>{link.label}</a>)}

				<details class="shared-mobile-submenu">
					<summary
						class="shared-mobile-submenu-trigger"
						aria-expanded="false"
						aria-controls={mobileSubmenuPanelId}
					>
						<span>Other</span>
						<img src="/icons/chevron-down.svg" alt="" width="16" height="16" />
					</summary>
					<div class="shared-mobile-submenu-panel" id={mobileSubmenuPanelId}>
						{siteConfig.extraPages.map((link) => <a href={link.href}>{link.label}</a>)}
					</div>
				</details>

				<div class="shared-mobile-contact" aria-label="Contact links">
					<a class="shared-mobile-contact-link" href={`mailto:${siteConfig.email}`} aria-label={`Email ${siteConfig.email}`}>
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path d="M4.75 6.75h14.5v10.5H4.75z"></path>
							<path d="m5.25 7.25 6.75 5.5 6.75-5.5"></path>
						</svg>
					</a>
					{
						siteConfig.socialLinks.map((link) => (
							<a
								class="shared-mobile-contact-link"
								href={link.href}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={link.label}
							>
								{
									link.label === 'LinkedIn' ? (
										<svg viewBox="0 0 24 24" aria-hidden="true">
											<path d="M6.94 8.86H3.76v10.38h3.18V8.86Z"></path>
											<path d="M5.35 4.75a1.84 1.84 0 1 0 0 3.68 1.84 1.84 0 0 0 0-3.68Z"></path>
											<path d="M12.02 8.86H8.98v10.38h3.14v-5.13c0-1.35.26-2.66 1.94-2.66 1.64 0 1.66 1.54 1.66 2.75v5.04h3.15v-5.68c0-2.78-.6-4.93-3.86-4.93a3.38 3.38 0 0 0-3.04 1.67h-.04l.09-1.44Z"></path>
										</svg>
									) : link.label === 'Dribbble' ? (
										<svg viewBox="0 0 24 24" aria-hidden="true">
											<circle cx="12" cy="12" r="8.25"></circle>
											<path d="M5.45 7.1c4.9 1.9 7.65 6.1 8.2 12.58"></path>
											<path d="M3.8 13.2c5.15.25 9.75-1.1 13.8-4.1"></path>
											<path d="M10.15 20c1.75-4.3 5.1-6.85 10.05-7.65"></path>
										</svg>
									) : (
										<svg viewBox="0 0 24 24" aria-hidden="true">
											<path d="M8.25 15.75 15.75 8.25"></path>
											<path d="M9.5 6.75h7.75v7.75"></path>
											<path d="M6.75 17.25h10.5"></path>
										</svg>
									)
								}
							</a>
						))
					}
				</div>
			</nav>
		</details>
	</div>
</header>

<script is:inline>
	(() => {
		const menu = document.querySelector('.shared-menu');
		const button = menu?.querySelector('.shared-menu-trigger');
		if (!menu || !button) return;

		const setExpanded = (value) => {
			button.setAttribute('aria-expanded', String(value));
		};

		menu.addEventListener('focusin', () => setExpanded(true));
		menu.addEventListener('focusout', (event) => {
			if (!menu.contains(event.relatedTarget)) {
				setExpanded(false);
			}
		});
		menu.addEventListener('mouseenter', () => setExpanded(true));
		menu.addEventListener('mouseleave', () => setExpanded(false));
	})();

	(() => {
		const mobileMenu = document.querySelector('.shared-nav-mobile');
		if (!(mobileMenu instanceof HTMLDetailsElement)) return;

		const root = document.documentElement;
		const toggle = mobileMenu.querySelector('.shared-nav-toggle');
		const panel = mobileMenu.querySelector('.shared-mobile-panel');
		const submenu = mobileMenu.querySelector('.shared-mobile-submenu');
		const submenuToggle = submenu?.querySelector('.shared-mobile-submenu-trigger');
		const lockClass = 'shared-mobile-menu-open';
		const focusableSelector = [
			'a[href]',
			'button:not([disabled])',
			'summary',
			'[tabindex]:not([tabindex="-1"])',
		].join(',');

		const getFocusableItems = () =>
			Array.from(mobileMenu.querySelectorAll(focusableSelector)).filter((item) => {
				if (!(item instanceof HTMLElement)) return false;
				return !item.hasAttribute('disabled') && item.offsetParent !== null;
			});

		const closeMobileMenu = () => {
			mobileMenu.open = false;
			if (toggle instanceof HTMLElement) {
				toggle.focus();
			}
		};

		const syncScrollLock = () => {
			root.classList.toggle(lockClass, mobileMenu.open);
			toggle?.setAttribute('aria-expanded', String(mobileMenu.open));
		};

		submenu?.addEventListener('toggle', () => {
			submenuToggle?.setAttribute('aria-expanded', String(submenu.open));
		});
		mobileMenu.addEventListener('toggle', syncScrollLock);
		mobileMenu.addEventListener('keydown', (event) => {
			if (!mobileMenu.open) return;

			if (event.key === 'Escape') {
				event.preventDefault();
				closeMobileMenu();
				return;
			}

			if (event.key !== 'Tab') return;

			const focusableItems = getFocusableItems();
			const firstItem = focusableItems[0];
			const lastItem = focusableItems[focusableItems.length - 1];

			if (!firstItem || !lastItem) return;

			if (event.shiftKey && document.activeElement === firstItem) {
				event.preventDefault();
				lastItem.focus();
			} else if (!event.shiftKey && document.activeElement === lastItem) {
				event.preventDefault();
				firstItem.focus();
			}
		});
		panel?.addEventListener('click', (event) => {
			if (event.target instanceof Element && event.target.closest('a[href]')) {
				mobileMenu.open = false;
			}
		});
		window.addEventListener('pagehide', () => root.classList.remove(lockClass));
		syncScrollLock();
	})();
</script>
