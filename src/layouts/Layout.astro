---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import { SEO } from 'astro-seo';
import { siteConfig } from '../config/site';

const {
	title = siteConfig.title,
	description = siteConfig.description,
	showFooterCta = true,
	noindex = false,
	ogType = 'website',
	ogImage = siteConfig.ogImage,
	ogImageAlt = siteConfig.title,
	schema,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, siteConfig.siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteConfig.siteUrl).toString();
const schemaData =
	schema ??
	[
		{
			'@context': 'https://schema.org',
			'@type': 'WebSite',
			name: siteConfig.name,
			url: siteConfig.siteUrl,
			description: siteConfig.description,
			inLanguage: siteConfig.locale,
		},
		{
			'@context': 'https://schema.org',
			'@type': 'Person',
			name: siteConfig.authorName,
			jobTitle: siteConfig.authorRole,
			url: siteConfig.siteUrl,
			email: siteConfig.email,
		},
		{
			'@context': 'https://schema.org',
			'@type': 'WebPage',
			name: title,
			url: canonicalUrl,
			description,
			isPartOf: {
				'@type': 'WebSite',
				name: siteConfig.name,
				url: siteConfig.siteUrl,
			},
			inLanguage: siteConfig.locale,
		},
	];
---

<!doctype html>
<html lang={siteConfig.locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="color-scheme" content="light dark" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link
			rel="alternate"
			type="application/rss+xml"
			title={title + ' — RSS Feed'}
			href={new URL('/rss.xml', siteConfig.siteUrl).toString()}
		/>
		<link
			rel="preload"
			href="/fonts/manrope-latin-wght-normal.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<SEO
			title={title}
			titleDefault={siteConfig.title}
			description={description}
			canonical={canonicalUrl}
			noindex={noindex}
			openGraph={{
				basic: {
					title,
					type: ogType,
					image: ogImageUrl,
					url: canonicalUrl,
				},
				optional: {
					description,
					locale: siteConfig.locale.replace('-', '_'),
					siteName: siteConfig.name,
				},
				image: {
					alt: ogImageAlt,
				},
			}}
			twitter={{
				card: 'summary_large_image',
				title,
				description,
				image: ogImageUrl,
				imageAlt: ogImageAlt,
			}}
			extend={{
				meta: [
					{ name: 'keywords', content: siteConfig.keywords.join(', ') },
					{ name: 'author', content: siteConfig.authorName },
				],
			}}
		/>
		<link rel="stylesheet" href="/cookie-consent.css" />
		<script type="application/ld+json" set:html={JSON.stringify(schemaData)}></script>
		<script is:inline>
			(() => {
				const storageKey = 'leaftix-theme';
				const root = document.documentElement;
				const storedTheme = localStorage.getItem(storageKey);
				const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches
					? 'dark'
					: 'light';
				root.dataset.theme = storedTheme === 'dark' || storedTheme === 'light' ? storedTheme : systemTheme;
			})();
		</script>
	</head>
	<body>
		<slot />
		<SiteFooter showCta={showFooterCta} />
		<script src="/cookie-consent.js" defer></script>
		<script is:inline>
			(() => {
				const storageKey = 'leaftix-theme';
				const root = document.documentElement;
				const toggle = document.querySelector('[data-theme-toggle]');
				if (!toggle) {
					return;
				}

				const applyTheme = (theme) => {
					root.dataset.theme = theme;
					toggle.setAttribute('aria-pressed', String(theme === 'dark'));
					toggle.setAttribute(
						'aria-label',
						theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode',
					);
				};

				applyTheme(root.dataset.theme === 'dark' ? 'dark' : 'light');

				toggle.addEventListener('click', () => {
					const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
					localStorage.setItem(storageKey, nextTheme);
					applyTheme(nextTheme);
				});

				const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
				mediaQuery.addEventListener('change', (event) => {
					if (localStorage.getItem(storageKey)) {
						return;
					}

					applyTheme(event.matches ? 'dark' : 'light');
				});
			})();
		</script>
	</body>
</html>

<style is:global>
	@font-face {
		font-family: 'Manrope Variable';
		font-style: normal;
		font-display: optional;
		font-weight: 200 800;
		src: url('/fonts/manrope-latin-wght-normal.woff2') format('woff2-variations');
		unicode-range:
			U+0000-00FF,
			U+0131,
			U+0152-0153,
			U+02BB-02BC,
			U+02C6,
			U+02DA,
			U+02DC,
			U+0304,
			U+0308,
			U+0329,
			U+2000-206F,
			U+20AC,
			U+2122,
			U+2191,
			U+2193,
			U+2212,
			U+2215,
			U+FEFF,
			U+FFFD;
	}

	:root {
		color-scheme: light;
		--background: #ffffff;
		--foreground: #171717;
		--muted: #f7f7f7;
		--muted-foreground: #676767;
		--border: #d9d9d9;
		--control-border: #d0d0d0;
		--border-strong: #232323;
		--card: #ffffff;
		--card-foreground: #171717;
		--ring: #171717;
		--selection: #dcff68;
		--accent-link: #5869d8;
		--shadow-soft: 0 18px 36px rgba(23, 23, 23, 0.08);
		--shadow-medium: 0 18px 40px rgba(23, 23, 23, 0.08);
		--shadow-large: 0 20px 50px rgba(23, 23, 23, 0.08);
		--icon-filter: none;
		--font-sans: 'Manrope Variable', 'Inter', 'Segoe UI', sans-serif;
		--font-mono:
			'SFMono-Regular',
			'SF Mono',
			'Roboto Mono',
			'IBM Plex Mono',
			'Segoe UI Mono',
			'Consolas',
			'Liberation Mono',
			monospace;
		--container: 72rem;
	}

	:root[data-theme='dark'] {
		color-scheme: dark;
		--background: #0d1014;
		--foreground: #f5f7fb;
		--muted: #171b22;
		--muted-foreground: #a3acb9;
		--border: #2a313c;
		--control-border: #495566;
		--border-strong: #e3e9f3;
		--card: #151a21;
		--card-foreground: #f5f7fb;
		--ring: #dce7ff;
		--selection: #c6f142;
		--accent-link: #9dacff;
		--shadow-soft: 0 18px 36px rgba(0, 0, 0, 0.35);
		--shadow-medium: 0 18px 40px rgba(0, 0, 0, 0.4);
		--shadow-large: 0 20px 50px rgba(0, 0, 0, 0.42);
		--icon-filter: invert(1) brightness(1.15);
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 0;
		min-height: 100vh;
		font-family: var(--font-sans);
		color: var(--foreground);
		background-color: var(--background);
		transition:
			background-color 180ms ease,
			color 180ms ease,
			border-color 180ms ease;
	}

	html.shared-mobile-menu-open,
	html.shared-mobile-menu-open body {
		overflow: hidden;
	}

	a {
		color: inherit;
	}

	img {
		display: block;
		max-width: 100%;
	}

	button,
	input,
	textarea {
		font: inherit;
	}

	button {
		background: none;
		border: 0;
		padding: 0;
	}

	:focus-visible {
		outline: 3px solid var(--ring);
		outline-offset: 3px;
	}

	::selection {
		background: var(--selection);
		color: var(--foreground);
	}

	.skip-link {
		position: absolute;
		left: 1rem;
		top: 1rem;
		z-index: 100;
		padding: 0.75rem 1rem;
		background: var(--foreground);
		color: var(--background);
		text-decoration: none;
		transform: translateY(-160%);
		transition: transform 100ms linear;
		border-radius: 999px;
	}

	.skip-link:focus-visible {
		transform: translateY(0);
	}

	.shared-header {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-top: 0.25rem;
	}

	.shared-header-actions {
		display: flex;
		align-items: center;
		gap: 0.85rem;
	}

	.shared-brand {
		display: inline-flex;
		align-items: center;
		min-height: 44px;
		text-decoration: none;
	}

	.shared-brand-mark {
		font-size: 1.3rem;
		font-weight: 800;
		letter-spacing: -0.04em;
	}

	.shared-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 2rem;
	}

	.shared-nav-mobile {
		display: none;
		margin-left: auto;
		position: relative;
	}

	.shared-nav a {
		min-height: 44px;
		display: inline-flex;
		align-items: center;
		font-size: 0.95rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		text-decoration: none;
	}

	.shared-menu {
		position: relative;
		padding-bottom: 0.45rem;
		margin-bottom: -0.45rem;
	}

	.shared-menu-trigger {
		list-style: none;
		min-height: 44px;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		cursor: pointer;
		padding: 0;
		font-size: 0.95rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--foreground);
		text-decoration: none;
		transition: opacity 120ms ease;
	}

	.shared-nav-toggle::-webkit-details-marker,
	.shared-mobile-submenu-trigger::-webkit-details-marker {
		display: none;
	}

	.shared-menu-trigger img {
		filter: var(--icon-filter);
		transition: transform 140ms ease;
	}

	.shared-menu:hover .shared-menu-trigger img,
	.shared-menu:focus-within .shared-menu-trigger img {
		transform: rotate(180deg);
	}

	.shared-nav a:hover,
	.shared-menu-trigger:hover {
		opacity: 0.68;
	}

	.shared-nav a:focus-visible,
	.shared-menu-trigger:focus-visible {
		opacity: 0.68;
	}

	.shared-menu-panel {
		position: absolute;
		top: calc(100% - 0.1rem);
		right: 0;
		min-width: 15rem;
		padding: 0.55rem;
		display: none;
		gap: 0.15rem;
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: 0.9rem;
		box-shadow: var(--shadow-soft);
		z-index: 20;
	}

	.shared-menu:hover .shared-menu-panel,
	.shared-menu:focus-within .shared-menu-panel {
		display: grid;
	}

	.shared-menu-panel a {
		min-height: 40px;
		display: flex;
		align-items: center;
		padding: 0.4rem 0.6rem;
		border-radius: 0.65rem;
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
		transition: background-color 120ms ease;
	}

	.shared-menu-panel a:hover,
	.shared-menu-panel a:focus-visible {
		background: var(--muted);
		text-decoration: none;
	}

	.shared-nav-toggle {
		list-style: none;
		min-height: 44px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.35rem 0;
		cursor: pointer;
	}

	.shared-theme-toggle {
		width: 44px;
		height: 44px;
		display: inline-grid;
		place-items: center;
		border: 1px solid var(--control-border);
		border-radius: 50%;
		color: var(--foreground);
		cursor: pointer;
		transition:
			background-color 120ms ease,
			border-color 120ms ease,
			transform 120ms ease;
	}

	.shared-theme-toggle:hover,
	.shared-theme-toggle:focus-visible {
		background: var(--muted);
		border-color: var(--border-strong);
		transform: translateY(-1px);
	}

	.shared-theme-toggle-icons {
		position: relative;
		width: 1.2rem;
		height: 1.2rem;
		display: inline-grid;
		place-items: center;
	}

	.shared-theme-icon {
		position: absolute;
		width: 1.2rem;
		height: 1.2rem;
		transition:
			opacity 160ms ease,
			transform 160ms ease;
	}

	.shared-theme-icon-sun {
		opacity: 1;
		transform: scale(1) rotate(0deg);
	}

	.shared-theme-icon-moon {
		opacity: 0;
		transform: scale(0.7) rotate(-20deg);
	}

	:root[data-theme='dark'] .shared-theme-icon-sun {
		opacity: 0;
		transform: scale(0.7) rotate(20deg);
	}

	:root[data-theme='dark'] .shared-theme-icon-moon {
		opacity: 1;
		transform: scale(1) rotate(0deg);
	}

	.shared-nav-toggle-box {
		display: inline-grid;
		gap: 0.22rem;
	}

	.shared-nav-toggle-box span {
		width: 1.1rem;
		height: 2px;
		background: var(--foreground);
		border-radius: 999px;
		transition: transform 140ms ease, opacity 140ms ease;
	}

	.shared-nav-mobile[open] .shared-nav-toggle-box span:nth-child(1) {
		transform: translateY(6px) rotate(45deg);
	}

	.shared-nav-mobile[open] .shared-nav-toggle-box span:nth-child(2) {
		opacity: 0;
	}

	.shared-nav-mobile[open] .shared-nav-toggle-box span:nth-child(3) {
		transform: translateY(-6px) rotate(-45deg);
	}

	.shared-mobile-panel {
		margin-top: 0.9rem;
		width: min(18rem, calc(100vw - 1.5rem));
		padding: 0.85rem;
		display: grid;
		gap: 0.35rem;
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: 1rem;
		box-shadow: var(--shadow-soft);
	}

	.shared-mobile-submenu {
		width: 100%;
	}

	.shared-mobile-brand {
		text-decoration: none;
	}

	.shared-mobile-panel a,
	.shared-mobile-submenu-trigger {
		min-height: 44px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.5rem 0.65rem;
		border-radius: 0.75rem;
		font-size: 0.98rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		text-decoration: none;
	}

	.shared-mobile-panel a:hover,
	.shared-mobile-panel a:focus-visible,
	.shared-mobile-submenu-trigger:hover,
	.shared-mobile-submenu-trigger:focus-visible {
		background: var(--muted);
	}

	.shared-mobile-submenu-trigger {
		list-style: none;
		cursor: pointer;
	}

	.shared-mobile-submenu-trigger img {
		filter: var(--icon-filter);
		transition: transform 140ms ease;
	}

	.shared-mobile-submenu[open] .shared-mobile-submenu-trigger img {
		transform: rotate(180deg);
	}

	.shared-mobile-submenu-panel {
		margin-top: 0.35rem;
		padding: 0.15rem 0 0.25rem 0.85rem;
		display: grid;
		gap: 0.2rem;
	}

	.shared-mobile-submenu-panel a {
		padding-left: 0.8rem;
	}

	.shared-mobile-contact {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding-top: 0.85rem;
	}

	.shared-mobile-panel .shared-mobile-contact-link {
		width: 46px;
		height: 46px;
		display: inline-grid;
		place-items: center;
		justify-content: center;
		min-height: 0;
		padding: 0;
		border: 1px solid var(--control-border);
		border-radius: 50%;
		color: var(--foreground);
		text-decoration: none;
		transition:
			background-color 120ms ease,
			border-color 120ms ease,
			transform 120ms ease;
	}

	.shared-mobile-panel .shared-mobile-contact-link svg {
		width: 1.15rem;
		height: 1.15rem;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.8;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.shared-mobile-panel .shared-mobile-contact-link[aria-label='LinkedIn'] svg {
		fill: currentColor;
		stroke: none;
	}

	.shared-mobile-panel .shared-mobile-contact-link:hover,
	.shared-mobile-panel .shared-mobile-contact-link:focus-visible {
		background: var(--muted);
		border-color: var(--border-strong);
		transform: translateY(-1px);
	}

	.display-title {
		width: 100%;
		max-width: none;
		margin: 1rem 0 0;
		font-size: clamp(3rem, 4.8vw, 5rem);
		line-height: 1.02;
		letter-spacing: -0.05em;
		font-weight: 800;
		color: var(--foreground);
	}

	.shared-footer {
		padding: 0 0 3rem;
	}

	.shared-footer-inner {
		width: min(calc(100% - 3rem), 78rem);
		margin: 0 auto;
		padding-top: 3rem;
		border-top: 1px solid var(--border);
	}

	.shared-footer-cta h2 {
		margin: 0;
		font-size: clamp(1.7rem, 3vw, 2.4rem);
		line-height: 1.08;
		letter-spacing: -0.04em;
	}

	.shared-footer-cta p,
	.shared-footer-cta a,
	.shared-footer-meta p,
	.shared-footer-links a {
		font-size: 1rem;
		line-height: 1.7;
	}

	.shared-footer-cta p {
		max-width: none;
		margin: 1rem 0 0;
		color: var(--muted-foreground);
	}

	.shared-footer-cta a {
		display: inline-block;
		margin-top: 0.75rem;
		color: var(--accent-link);
		text-decoration: none;
	}

	.shared-footer-cta .shared-footer-inline-link {
		display: inline;
		margin-top: 0;
		color: inherit;
		font-weight: 700;
	}

	.shared-footer-cta a:hover,
	.shared-footer-cta a:focus-visible,
	.shared-footer-links a:hover,
	.shared-footer-links a:focus-visible {
		text-decoration: underline;
	}

	.shared-footer-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 2rem;
		padding-top: 1rem;
		border-top: 1px solid var(--border);
	}

	.shared-footer-inner-no-cta .shared-footer-meta {
		margin-top: 0;
		padding-top: 0;
		border-top: 0;
	}

	.shared-footer-meta p {
		margin: 0;
		color: var(--muted-foreground);
	}

	.shared-footer-note {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.35rem;
	}

	.shared-footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.shared-footer-links a {
		color: var(--foreground);
		text-decoration: none;
	}

	.shared-footer-legal {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: flex-end;
	}

	.shared-footer-legal a,
	.footer-cookie-btn {
		font-size: 0.92rem;
		line-height: 1.4;
		color: var(--muted-foreground);
		text-decoration: none;
	}

	.shared-footer-legal a:hover,
	.shared-footer-legal a:focus-visible,
	.footer-cookie-btn:hover,
	.footer-cookie-btn:focus-visible {
		text-decoration: underline;
	}

	@media (prefers-reduced-motion: reduce) {
		html {
			scroll-behavior: auto;
		}

		*,
		*::before,
		*::after {
			animation: none !important;
			transition-duration: 0ms !important;
		}
	}

	@media (max-width: 720px) {
		.display-title {
			font-size: clamp(2.4rem, 10vw, 3.4rem);
		}

		.shared-header {
			gap: 0.75rem;
			align-items: center;
			justify-content: space-between;
			flex-wrap: nowrap;
		}

		.shared-header-actions {
			margin-left: auto;
		}

		.shared-nav-desktop {
			display: none;
		}

		.shared-nav-mobile {
			display: block;
		}

		.shared-nav-mobile[open] {
			z-index: 50;
		}

		.shared-nav-mobile[open] .shared-nav-toggle {
			margin-left: auto;
			position: relative;
			z-index: 60;
		}

		.shared-nav-mobile[open] .shared-mobile-panel {
			position: fixed;
			inset: 0;
			width: auto;
			min-height: 100vh;
			min-height: 100dvh;
			margin: 0;
			padding: 6rem 1.25rem 2rem;
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 0.55rem;
			background: var(--background);
			border: 0;
			border-radius: 0;
			box-shadow: none;
			overflow-x: hidden;
			overflow-y: auto;
			z-index: 50;
		}

		.shared-mobile-panel > a,
		.shared-mobile-submenu {
			width: min(100%, 24rem);
		}

		.shared-mobile-panel .shared-mobile-brand {
			position: fixed;
			top: 1rem;
			left: 0.75rem;
			z-index: 55;
			width: auto;
			min-height: 44px;
			margin-bottom: 0;
			padding: 0;
			display: inline-flex;
			align-items: center;
